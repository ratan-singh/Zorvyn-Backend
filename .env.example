# ═══════════════════════════════════════════════════════════════
# Finance Dashboard API — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_dashboard
DB_USERNAME=postgres
DB_PASSWORD=

# JWT Configuration
# Must be a 256-bit (32-byte) base64-encoded secret for HS256
JWT_SECRET_KEY=your-256-bit-base64-encoded-secret-key
# Token validity in milliseconds (default: 86400000 = 24 hours)
JWT_EXPIRATION_MS=86400000

# Server
SERVER_PORT=8080

# Allowed CORS origins (comma-separated for multiple)
CORS_ALLOWED_ORIGINS=http://localhost:3000
